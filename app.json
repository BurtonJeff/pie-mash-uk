{
  "expo": {
    "name": "Pie & Mash",
    "slug": "pie-mash-uk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pie-mash-uk",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D5016"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uk.org.pml.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.piemashanduk.app",
      "config": {
        "googleMaps": {
          "apiKey": "GOOGLE_MAPS_ANDROID_API_KEY_PLACEHOLDER"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#2D5016"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Pie & Mash uses Face ID to sign you in quickly and securely."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Pie & Mash needs calendar access to add meatup events.",
          "remindersPermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4617c1e4-b369-4f14-88d1-8e11029a2d4c"
      }
    },
    "owner": "jeffburton"
  }
}
